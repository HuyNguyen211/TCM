# ---- Core ----
PORT=4000
# 'mock' = zero-setup in-memory/JSON store (default). 'sheets' = real Google Sheets.
DB_MODE=mock
# Comma-separated allowed origins, or * for all (dev).
CORS_ORIGIN=http://localhost:5173

# ---- Auth (email+password JWT) ----
# MUST set a long random value in production (passwords are scrypt-hashed; tokens signed with this).
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ---- Mock mode ----
# Where JSON "sheets" are persisted (relative to backend/).
DATA_DIR=data

# ---- Google Sheets mode (only when DB_MODE=sheets) ----
SHEET_ID=
# Option A: path to service-account key file
GOOGLE_APPLICATION_CREDENTIALS=
# Option B: raw service-account JSON (handy on Railway/Render). Use ONE of A or B.
GOOGLE_SERVICE_ACCOUNT_KEY=

# ---- Integrations (optional — for future Jira/Figma functions) ----
# Atlassian (Jira) Cloud REST API. Token: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_BASE_URL=
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=
# Figma REST API. Token: Figma → Settings → Security → Personal access tokens
FIGMA_TOKEN=

# ---- AI (Claude) — powers "Gen Testcase with AI" ----
# Use ONE of the two (API key wins if both are set).
# Option A (recommended for a server): API key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Option B: OAuth Bearer token from the Anthropic CLI:
#   ant auth login   then   ant auth print-credentials --access-token
# NOTE: OAuth tokens are short-lived and NOT auto-refreshed — re-paste before they expire.
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=claude-opus-4-8
